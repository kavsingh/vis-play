{
	"name": "vis-play",
	"version": "0.0.0",
	"private": true,
	"description": "playing with vis",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"repository": {
		"type": "git",
		"url": "git@github.com:kavsingh/vis-play"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "nx run-many -t dev --outputStyle stream",
		"build": "nx build vis",
		"test": "nx run-many -t test --outputStyle stream",
		"lint": "nx run-many -t lint --outputStyle stream",
		"preview": "nx preview vis",
		"clean:nx": "rimraf ./**/.nx --glob",
		"clean:modules": "rimraf ./**/node_modules --glob",
		"clean:targets": "rimraf ./**/target --glob"
	},
	"devDependencies": {
		"@tsconfig/bun": "1.0.10",
		"@tsconfig/strictest": "2.0.8",
		"@types/bun": "1.3.12",
		"@typescript/native-preview": "7.0.0-dev.20260410.1",
		"cross-env": "10.1.0",
		"lefthook": "2.1.5",
		"nx": "22.6.5",
		"oxfmt": "0.44.0",
		"oxlint": "1.59.0",
		"oxlint-tsgolint": "0.20.0",
		"rimraf": "6.1.3",
		"tombi": "0.9.16"
	},
	"trustedDependencies": [
		"lefthook",
		"nx",
		"tombi"
	]
}
